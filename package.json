{
  "name": "aplicativo-mercado",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@expo/vector-icons": "15.0.3",
    "expo-font": "14.0.11",
    "react": "19.1.0",
    "react-native-safe-area-context": "5.6.2"
  },
  "devDependencies": {
    "@expo/vector-icons": "15.0.3",
    "@types/react": "19.1.17",
    "expo-font": "14.0.11",
    "metro-runtime": "^0.83.3",
    "react": "19.1.0",
    "react-native-safe-area-context": "5.6.2"
  },
  "scripts": {
    "mobile": "npm run start --workspace @mercado/mobile",
    "mobile:tunnel": "npm run tunnel --workspace @mercado/mobile",
    "mobile:lan": "npm run lan --workspace @mercado/mobile",
    "mobile:lan:fixed": "npm run lan:fixed --workspace @mercado/mobile",
    "mobile:local": "npm run local --workspace @mercado/mobile",
    "webhooks": "npm run dev --workspace @mercado/webhooks",
    "typecheck": "npm run typecheck --workspace @mercado/mobile && npm run typecheck --workspace @mercado/webhooks && npm run typecheck --workspace @mercado/shared"
  }
}
