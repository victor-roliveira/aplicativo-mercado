{
  "name": "@mercado/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "tunnel": "npx expo start --tunnel -c",
    "lan": "npx expo start --lan -c",
    "lan:fixed": "set REACT_NATIVE_PACKAGER_HOSTNAME=192.168.0.8 && npx expo start --lan -c",
    "local": "npx expo start --localhost -c",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "15.0.3",
    "@mercado/shared": "*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@supabase/supabase-js": "^2.49.4",
    "expo": "~54.0.0",
    "expo-font": "14.0.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-paper": "^5.13.1",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "19.1.17",
    "typescript": "^5.8.3"
  }
}
